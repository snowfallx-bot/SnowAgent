{
  "name": "agent-orchestrator",
  "version": "0.1.0",
  "description": "Windows-friendly local multi-agent CLI orchestrator for Codex, Copilot, and Qwen-style CLIs.",
  "private": true,
  "type": "commonjs",
  "bin": {
    "agent-orchestrator": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli/index.js",
    "test": "vitest run --environment node",
    "test:watch": "vitest --environment node"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "yaml": "^2.8.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.7"
  }
}
